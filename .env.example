APP_NAME="URL Analytics"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=url_analytics
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_DRIVER=database
CACHE_PREFIX=url_analytics

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@urlanalytics.dev"
MAIL_FROM_NAME="${APP_NAME}"

# URL Shortener settings
URL_SHORTENER_CODE_LENGTH=7
URL_SHORTENER_DOMAIN="${APP_URL}"
URL_SHORTENER_MAX_PER_USER=500
URL_SHORTENER_DEFAULT_EXPIRY_DAYS=365

# Rate limiting (requests per minute)
RATE_LIMIT_SHORTEN=10
RATE_LIMIT_REDIRECT=120

# Analytics
ANALYTICS_QUEUE=analytics
GEO_IP_PROVIDER=ipapi

# IP geolocation (ipapi.co — 1000 free requests/day)
IPAPI_BASE_URL=https://ipapi.co

# Swagger / API Docs
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_DOC_EXPANSION=none
